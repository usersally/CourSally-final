# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# Option A (recommended): full URI with credentials
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/courSally?retryWrites=true&w=majority
# Option B: host-only URI + separate credentials (supported by db.ts)
MONGODB_URI=mongodb+srv://cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=courSally
MONGODB_USERNAME=your_db_user
MONGODB_PASSWORD=your_db_password

# ============================================
# Authentication (JWT)
# ============================================
AUTH_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# ============================================
# CORS
# ============================================
# Comma-separated allowed origins. Vercel *.vercel.app is also allowed automatically.
FRONTEND_DOMAIN=http://localhost:3000,https://your-app.vercel.app

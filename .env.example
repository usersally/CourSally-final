# ============================================
# Server Configuration
# ============================================
PORT=3000 # Port the server listens on
NODE_ENV=development # 'development' or 'production'
# ============================================
# Database Configuration
# ============================================
# Local MongoDB: mongodb://localhost:27017
# MongoDB Atlas / Railway: mongodb+srv://<user>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=book_management
MONGODB_USERNAME=
MONGODB_PASSWORD=
# ============================================
# Authentication (JWT)
# ============================================
AUTH_SECRET=your-super-secret-key-min-32-chars # Secret for signing JWTs (npx auth secret)
JWT_EXPIRES_IN=7d # Token lifetime (e.g., '1h', '7d', '30d')
# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=CourSally <noreply@coursally.com>
# ============================================
# CORS
# ============================================
FRONTEND_DOMAIN=http://localhost:3000
# ============================================
# Server Configuration
# ============================================
PORT=3000 # Port the server listens on
NODE_ENV=development # 'development' or 'production'
# ============================================
# Database Configuration
# ============================================
MONGODB_URI=mongodb://localhost:27017 # MongoDB connection string
MONGODB_DB_NAME=book_management # Database name
MONGODB_USERNAME= # Optional: DB auth username
MONGODB_PASSWORD= # Optional: DB auth password
# ============================================
# Authentication (JWT)
# ============================================
AUTH_SECRET=your-super-secret-key-min-32-chars # Secret for signing JWTs (npx auth secret)
JWT_EXPIRES_IN=7d # Token lifetime (e.g., '1h', '7d', '30d')
# ============================================
# CORS
# ============================================
FRONTEND_DOMAIN=http://localhost:5173 # Allowed origin for CORS